# ============================================================
# RRK Automations — environment variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# ============================================================

# ---- Frontend (Vite, exposed to the browser — public keys only) ----

# Supabase project the site talks to
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# Public anon/publishable key (safe to expose; protected by RLS)
VITE_SUPABASE_PUBLISHABLE_KEY=""

# Calendly booking URL the Lead Gate redirects to after capturing a lead
VITE_CALENDLY_URL="https://calendly.com/rrkautomations/new-meeting"


# ============================================================
# Backend — Supabase Edge Function secrets (submit-lead)
# NOT exposed to the browser. Set with the Supabase CLI:
#   supabase secrets set KEY=value
# Do NOT prefix these with VITE_.
# ============================================================

# EmailJS — server-side send (enable "Allow EmailJS API for
# non-browser applications" in EmailJS account security settings)
# EMAILJS_SERVICE_ID=""
# EMAILJS_TEMPLATE_ID_INTERNAL=""
# EMAILJS_PUBLIC_KEY=""
# EMAILJS_PRIVATE_KEY=""

# Comma-separated team members who receive new-lead emails
# LEAD_NOTIFY_TO="a@example.com,b@example.com,c@example.com,d@example.com,e@example.com"

# Auto-injected by Supabase into Edge Functions (do not set manually):
#   SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY
